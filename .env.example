# Arrow Limousine Management System - Environment Configuration
# Copy this file to .env and fill in your database credentials
# NEVER commit .env to git - .env is in .gitignore

# ============================================================================
# NETWORK POSTGRESQL CONFIGURATION (Primary - Dual Dispatcher Setup)
# ============================================================================
# Both DISPATCHMAIN and DISPATCH1 connect to same PostgreSQL server
# 
# DISPATCHMAIN (server): DB_HOST=localhost
# DISPATCH1 (client):    DB_HOST=192.168.x.x (DISPATCHMAIN's IP address)
#
# Run SETUP_POSTGRESQL_NETWORK_ACCESS.ps1 on DISPATCHMAIN to enable network access

DB_HOST=localhost
DB_PORT=5432
DB_NAME=almsdata
DB_USER=postgres
# For password authentication:
DB_PASSWORD=your_postgres_password_here
# For Windows integrated authentication (SSPI):
# Leave DB_PASSWORD empty and run SETUP_WINDOWS_INTEGRATED_AUTH.ps1 as Administrator
# DB_PASSWORD=
DB_SSLMODE=prefer

# ============================================================================
# WORKSTATION IDENTIFICATION
# ============================================================================
# Set to DISPATCHMAIN or DISPATCH1 to identify which computer made changes
WORKSTATION_ID=DISPATCHMAIN

# ============================================================================
# CLOUD DATABASE (Optional - Neon Cloud Backup)
# ============================================================================
# Only needed if using cloud database instead of local network
# NEON_DB_HOST=your-neon-host.us-west-2.aws.neon.tech
# NEON_DB_NAME=neondb
# NEON_DB_USER=neondb_owner
# NEON_DB_PASSWORD=your_neon_password_here
# DB_SSLMODE=require

# ============================================================================
# API CONFIGURATION (Optional - for web app)
# ============================================================================
# Backend API URL for web access or sync features
API_URL=https://arrow-limo.onrender.com
API_TIMEOUT=30

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Set to true for verbose logging during troubleshooting
DEBUG=false

# Set your preferred timezone
TIMEZONE=America/Edmonton

# Email notifications (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATIONS_ENABLED=false
