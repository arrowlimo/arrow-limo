        ></textarea>
      </div>
    </div>

    <!-- PRICING & FEES -->
    <div class="form-section">
      <h3>💰 Pricing & Fees</h3>
      
      <div class="pricing-grid">
        <div class="price-row">
          <label>Base Rate</label>
          <input v-model.number="form.baseRate" type="number" step="0.01" placeholder="0.00" />
        </div>
        <div class="price-row">
          <label>Airport Fee</label>
          <input v-model.number="form.airportFee" type="number" step="0.01" placeholder="0.00" />
        </div>
        <div class="price-row">
          <label>Fuel Surcharge</label>
          <input v-model.number="form.fuelSurcharge" type="number" step="0.01" placeholder="0.00" />
        </div>
        <div class="price-row">
          <label>Gratuity</label>
          <input v-model.number="form.gratuity" type="number" step="0.01" placeholder="0.00" />
        </div>
        <div class="price-row total-row">
          <label>Total Amount Due</label>
          <input v-model.number="totalAmountDue" type="number" step="0.01" readonly />
        </div>
      </div>
    </div>

    <!-- QUOTE GENERATOR -->
    <div class="form-section quote-section">
      <h3>📊 Generate Quote</h3>
      <p class="help-text">Generate quotes for different vehicle types based on route and pricing</p>
      
      <div class="quote-controls">
        <label class="checkbox-label">
          <input type="checkbox" v-model="quoteMultiVehicle" />
          <span>Multi-vehicle quote (e.g., shuttle + limos for bride/groom)</span>
        </label>
      </div>

      <div v-if="quoteMultiVehicle" class="multi-vehicle-setup">
        <h4>Vehicle Combinations</h4>
        <div v-for="(config, idx) in vehicleConfigs" :key="idx" class="vehicle-config-row">
          <select v-model="config.type">
            <option value="sedan">Sedan</option>
            <option value="suv">SUV</option>
            <option value="stretch">Stretch Limo</option>
            <option value="shuttle">Shuttle Bus</option>
            <option value="party_bus">Party Bus</option>
          </select>
          <input v-model.number="config.quantity" type="number" min="1" max="10" placeholder="Qty" class="qty-input" />
          <input v-model="config.purpose" type="text" placeholder="Purpose (e.g., 'Guest transport')" />
          <button type="button" @click="removeVehicleConfig(idx)" class="remove-btn">×</button>
        </div>
        <button type="button" @click="addVehicleConfig" class="add-btn">+ Add Vehicle</button>
      </div>

      <button type="button" @click="generateQuote" class="generate-quote-btn">
        🎯 Generate Quote
      </button>
    </div>

    <!-- ACTIONS -->
    <div class="form-actions">
      <button type="button" @click="saveCharter" class="btn-primary">
