          <input v-model="form.email" type="email" placeholder="customer@example.com" />
        </div>
      </div>
    </div>

    <!-- CHARTER BASIC INFO -->
    <div class="form-section">
      <h3>📅 Charter Information</h3>
      
      <div class="form-row-dual">
        <div class="form-field">
          <label>Charter Date *</label>
          <input v-model="form.charterDate" type="date" required />
        </div>
        <div class="form-field">
          <label>Pickup Time *</label>
          <input v-model="form.pickupTime" type="time" required />
        </div>
