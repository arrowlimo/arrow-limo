      <div class="form-row-dual">
        <div class="form-field">
          <label>Passenger Count *</label>
          <input v-model.number="form.passengerCount" type="number" min="1" max="50" required />
        </div>
        <div class="form-field">
          <label>Vehicle Type</label>
          <select v-model="form.vehicleType">
            <option value="">-- Select --</option>
            <option value="sedan">Sedan (1-4)</option>
            <option value="suv">SUV (1-6)</option>
            <option value="stretch">Stretch Limo (1-8)</option>
            <option value="shuttle">Shuttle Bus (8-15)</option>
            <option value="party_bus">Party Bus (16-26)</option>
            <option value="coach">Coach Bus (27-56)</option>
          </select>
        </div>
      </div>
    </div>

    <!-- INTERMEDIATE ROUTING STOPS -->
    <div class="form-section">
      <h3>🗺️ Routing Stops</h3>
      <div class="routing-controls">
        <button 
          type="button" 
          @click="form.routingLocked = !form.routingLocked" 
          :class="['lock-btn', form.routingLocked ? 'locked' : 'unlocked']"
        >
          {{ form.routingLocked ? '🔒 Locked - Click to Edit' : '🔓 Unlocked - Click to Lock' }}
        </button>
        <button 
          type="button" 
          @click="addRoutingStop" 
          class="add-route-btn"
          :disabled="form.routingLocked"
        >
          + Add Routing Stop
        </button>
      </div>

      <div class="routing-table">
        <div v-for="(stop, idx) in form.routingStops" :key="stop.id" class="routing-row">
          <div class="route-number">{{ idx + 1 }}</div>
          <input 
            v-model="stop.type" 
            type="text" 
            placeholder="Stop type (e.g., 'Stop At', 'Via')"
            class="route-type"
            :readonly="form.routingLocked"
          />
          <input 
            v-model="stop.address" 
            type="text" 
            placeholder="Address or location"
            class="route-address"
            :readonly="form.routingLocked"
          />
          <input 
            v-model="stop.time" 
            type="time" 
            class="route-time"
            :readonly="form.routingLocked"
          />
          <button 
            type="button" 
            @click="removeRoutingStop(idx)" 
            class="remove-btn"
            :disabled="form.routingLocked"
          >
            ×
          </button>
        </div>
        <p v-if="!form.routingStops.length" class="no-routes">
          No intermediate stops. Click "Add Routing Stop" to add waypoints.
        </p>
      </div>
    </div>

    <!-- SECONDARY B/A ROUTES (shown when Out of Town is checked) -->
    <div v-if="form.isOutOfTown" class="master-routes secondary-routes">
      <h3>🏁 Secondary Routes (Return)</h3>
      <div class="route-master-row">
        <div class="route-label">Secondary B</div>
        <div class="route-type-display">Drop Off At</div>
        <input 
          v-model="form.secondaryB.address" 
          type="text" 
          placeholder="Drop off address/location"
          class="route-input"
          :readonly="form.routingLocked"
        />
        <input 
          v-model="form.secondaryB.time" 
          type="time" 
          class="route-time"
          :readonly="form.routingLocked"
        />
      </div>

      <div class="route-master-row">
        <div class="route-label">Secondary A</div>
        <div class="route-type-display">Returned to Red Deer At</div>
        <input 
          v-model="form.secondaryA.address" 
          type="text" 
          placeholder="Return location in Red Deer"
          class="route-input"
          :readonly="form.routingLocked"
        />
        <input 
          v-model="form.secondaryA.time" 
