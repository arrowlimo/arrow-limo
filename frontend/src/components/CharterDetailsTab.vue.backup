<template>
  <div class="charter-details-tab">
    <!-- Out of Town Checkbox -->
    <div class="form-section highlight-section">
      <label class="checkbox-label">
        <input type="checkbox" v-model="form.isOutOfTown" @change="onOutOfTownChange" />
        <span class="checkbox-text">🌄 Out of Town Run</span>
      </label>
      <p class="help-text">Check if charter leaves Red Deer city limits</p>
    </div>

    <!-- PRIMARY A/B ROUTES (shown when Out of Town is checked) -->
    <div v-if="form.isOutOfTown" class="master-routes primary-routes">
      <h3>📍 Primary Routes (Departure)</h3>
      <div class="route-master-row">
        <div class="route-label">Primary A</div>
        <div class="route-type-display">Leave Red Deer For</div>
        <input 
