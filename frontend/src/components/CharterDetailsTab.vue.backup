      </button>
      <button type="button" @click="resetForm" class="btn-secondary">
        🔄 Reset Form
      </button>
    </div>
  </div>
</template>

<script setup>
import { ref, computed, watch } from 'vue'

const emit = defineEmits(['save', 'quote-generated'])

// Form state
const form = ref({
  isOutOfTown: false,
  routingLocked: false,
  
  // Master routes (only visible when isOutOfTown = true)
  primaryA: { address: '', time: '' },  // Leave Red Deer For
  primaryB: { address: '', time: '' },  // Pickup In
  secondaryB: { address: '', time: '' }, // Drop Off At
  secondaryA: { address: '', time: '' }, // Returned to Red Deer At
  primaryNotes: '',
  secondaryNotes: '',
  
  // Customer
  clientName: '',
  phone: '',
  email: '',
  
  // Charter basics
  charterDate: '',
  pickupTime: '',
  passengerCount: 1,
  vehicleType: '',
  
  // Intermediate routing stops (numbered 1, 2, 3...)
  routingStops: [],
  
  // Pricing
  baseRate: 0,
  airportFee: 0,
  fuelSurcharge: 0,
  gratuity: 0
})

// UI state
const showClientDropdown = ref(false)
const clientMatches = ref([])
const quoteMultiVehicle = ref(false)
const vehicleConfigs = ref([
  { type: 'shuttle', quantity: 2, purpose: 'Guest shuttles' },
  { type: 'stretch', quantity: 1, purpose: 'Bride & Groom' }
])

// Computed
const totalAmountDue = computed(() => {
  return (form.value.baseRate || 0) + 
         (form.value.airportFee || 0) + 
         (form.value.fuelSurcharge || 0) + 
         (form.value.gratuity || 0)
})

// Watchers - sync routing table changes back to master routes
watch(() => form.value.routingStops, (newStops) => {
  if (!form.value.isOutOfTown) return
  
  // Update master routes when routing table is edited
  updateMasterRoutesFromTable()
}, { deep: true })

// Methods
function onOutOfTownChange() {
  if  (form.value.isOutOfTown) {
    // Initialize master routes if not set
    if (!form.value.primaryA.address) {
      form.value.primaryA = { address: '', time: form.value.pickupTime }
    }
  }
}

function addRoutingStop() {
  form.value.routingStops.push({
    id: Date.now(),
    type: 'Stop At',
    address: '',
    time: ''
  })
}

function removeRoutingStop(idx) {
  form.value.routingStops.splice(idx, 1)
}

function updateMasterRoutesFromTable() {
  // This syncs any routing table edits back to the master route fields
  // Implementation depends on business logic
  console.log('Routing table updated, syncing to master routes')
}

function searchClients() {
  // TODO: API call to search clients
  showClientDropdown.value = true
}

function selectClient(client) {
  form.value.clientName = client.client_name
  form.value.phone = client.phone || ''
  form.value.email = client.email || ''
  showClientDropdown.value = false
}

function addVehicleConfig() {
  vehicleConfigs.value.push({
    type: 'sedan',
    quantity: 1,
    purpose: ''
  })
}

function removeVehicleConfig(idx) {
  vehicleConfigs.value.splice(idx, 1)
}

function generateQuote() {
  const quoteData = {
    charter: form.value,
    vehicles: quoteMultiVehicle.value ? vehicleConfigs.value : [
      { type: form.value.vehicleType, quantity: 1, purpose: 'Charter' }
    ]
  }
  
  emit('quote-generated', quoteData)
  console.log('Generating quote:', quoteData)
}

function saveCharter() {
  emit('save', form.value)
}

function resetForm() {
  if (confirm('Clear all form data?')) {
    form.value = {
      isOutOfTown: false,
      routingLocked: false,
      primaryA: { address: '', time: '' },
      primaryB: { address: '', time: '' },
      secondaryB: { address: '', time: '' },
      secondaryA: { address: '', time: '' },
      primaryNotes: '',
      secondaryNotes: '',
      clientName: '',
      phone: '',
      email: '',
      charterDate: '',
      pickupTime: '',
      passengerCount: 1,
      vehicleType: '',
      routingStops: [],
      baseRate: 0,
      airportFee: 0,
      fuelSurcharge: 0,
      gratuity: 0
    }
  }
}
</script>

