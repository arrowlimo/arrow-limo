          class="route-input"
          :readonly="form.routingLocked"
        />
        <input 
          v-model="form.primaryB.time" 
          type="time" 
          class="route-time"
          :readonly="form.routingLocked"
        />
      </div>

      <div class="route-notes">
        <label>Notes:</label>
        <textarea 
          v-model="form.primaryNotes" 
          rows="2" 
          placeholder="Client notes for departure and pickup"
          :readonly="form.routingLocked"
        ></textarea>
      </div>
    </div>

    <!-- CUSTOMER DETAILS -->
    <div class="form-section">
      <h3>👤 Customer Information</h3>
      
      <div class="form-row">
        <label>Customer Name *</label>
        <div class="autocomplete-wrapper">
          <input 
            v-model="form.clientName" 
            type="text" 
            @input="searchClients"
            @focus="showClientDropdown = true"
            placeholder="Search or enter customer name"
            autocomplete="off"
          />
          <ul v-if="showClientDropdown && clientMatches.length" class="dropdown">
            <li v-for="c in clientMatches" :key="c.client_id" @click="selectClient(c)">
              <strong>{{ c.client_name }}</strong>
              <small v-if="c.phone">{{ c.phone }}</small>
            </li>
          </ul>
        </div>
      </div>

      <div class="form-row-dual">
        <div class="form-field">
          <label>Phone</label>
          <input v-model="form.phone" type="tel" placeholder="(403) 555-1234" />
