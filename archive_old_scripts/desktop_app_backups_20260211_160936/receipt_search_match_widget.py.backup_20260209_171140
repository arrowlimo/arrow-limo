    def _fetch_banking_matches(self, receipt_id: int) -> List[tuple]:
        """Fetch banking transactions matching this receipt."""
        try:
            cur = self.conn.cursor()
            # Find the receipt first to get vendor/amount
            cur.execute(
                """SELECT vendor_name, gross_amount, banking_transaction_id, receipt_date
                   FROM receipts WHERE receipt_id = %s""",
                (receipt_id,)
            )
            receipt = cur.fetchone()
            cur.close()
            
            if not receipt:
                return []
            
            vendor, amount, linked_banking_id, rdate = receipt
            
            # Find banking transactions with similar vendor/amount (±$5, ±7 days)
            cur = self.conn.cursor()
            cur.execute(
                """SELECT banking_transaction_id, transaction_date, description, amount, 
                          posting_account, reference_number
                   FROM banking_transactions
                   WHERE description ILIKE %s
                   AND amount BETWEEN %s AND %s
                   AND transaction_date BETWEEN %s - INTERVAL '7 days' AND %s + INTERVAL '7 days'
                   ORDER BY ABS(amount - %s) ASC, transaction_date DESC
                   LIMIT 5""",
                (f"%{vendor}%", float(amount) - 5, float(amount) + 5, rdate, rdate, float(amount))
            )
            matches = cur.fetchall()
            cur.close()
            return matches
        except Exception as e:
            print(f"Banking match error: {e}")
            return []

    def _fetch_charter_matches(self, receipt_id: int) -> List[tuple]:
        """Fetch charters matching this receipt."""
        try:
            cur = self.conn.cursor()
            # Find the receipt's charter number or linked charter
            cur.execute(
                """SELECT reserve_number FROM receipts WHERE receipt_id = %s""",
                (receipt_id,)
            )
            row = cur.fetchone()
            cur.close()
            
            if not row or not row[0]:
                return []
            
            charter_num = row[0]
            
            # Fetch charter details
            cur = self.conn.cursor()
            cur.execute(
                """SELECT charter_id, charter_number, charter_date, vehicle_id, 
                          driver_id, customer_name, charter_amount
                   FROM charters
                   WHERE charter_number = %s OR reserve_number = %s
                   ORDER BY charter_date DESC
                   LIMIT 3""",
                (charter_num, charter_num)
            )
            matches = cur.fetchall()
            cur.close()
            return matches if matches else []
        except Exception as e:
            print(f"Charter match error: {e}")
            return []

    def _fetch_linked_matches(self, receipt_id: int) -> List[tuple]:
        """Fetch receipts linked to same banking transaction or charter."""
        try:
            cur = self.conn.cursor()
            # Find the receipt's banking_transaction_id and charter
            cur.execute(
                """SELECT banking_transaction_id, reserve_number FROM receipts WHERE receipt_id = %s""",
                (receipt_id,)
            )
            row = cur.fetchone()
            cur.close()
            
            if not row:
                return []
            
            banking_id, charter_num = row
            
            # Find other receipts with same banking_id or charter
            conditions = []
            params = []
            
            if banking_id:
                conditions.append("(banking_transaction_id = %s AND receipt_id != %s)")
                params.extend([banking_id, receipt_id])
            
            if charter_num:
                if conditions:
                    conditions.insert(1, "OR")
                    conditions.append("(reserve_number = %s AND receipt_id != %s)")
                    params.extend([charter_num, receipt_id])
                else:
                    conditions.append("(reserve_number = %s AND receipt_id != %s)")
                    params.extend([charter_num, receipt_id])
            
            if not conditions:
                return []
            
            cur = self.conn.cursor()
            where_clause = " ".join(conditions)
            sql = f"""SELECT receipt_id, receipt_date, vendor_name, gross_amount, 
                             gl_account_name, banking_transaction_id, reserve_number
                      FROM receipts
                      WHERE {where_clause}
                      ORDER BY receipt_date DESC, receipt_id DESC
                      LIMIT 5"""
            cur.execute(sql, params)
            matches = cur.fetchall()
            cur.close()
            return matches
        except Exception as e:
            print(f"Linked match error: {e}")
            return []

    def _show_split_matches(self, receipt_id: int):
        """Populate and show the split matches pane for a receipt."""
        try:
            # Clear all lists
            self.banking_matches_list.clear()
            self.charter_matches_list.clear()
            self.linked_receipts_list.clear()
            
            # Fetch and display banking matches
            banking_matches = self._fetch_banking_matches(receipt_id)
            if banking_matches:
                for btxn_id, bdate, bdesc, bamount, bacc, bref in banking_matches:
                    item_text = f"#{btxn_id} • {bdate} • {bdesc[:40]} • ${bamount:,.2f}"
                    item = QListWidgetItem(item_text)
                    item.setData(Qt.ItemDataRole.UserRole, btxn_id)
                    self.banking_matches_list.addItem(item)
            else:
                self.banking_matches_list.addItem("No banking matches found")
            
            # Fetch and display charter matches
            charter_matches = self._fetch_charter_matches(receipt_id)
            if charter_matches:
                for c_id, c_num, c_date, v_id, d_id, cust, c_amt in charter_matches:
                    item_text = f"#{c_num} • {c_date} • {cust or 'N/A'} • ${c_amt:,.2f}"
                    item = QListWidgetItem(item_text)
                    item.setData(Qt.ItemDataRole.UserRole, c_id)
                    self.charter_matches_list.addItem(item)
            else:
                self.charter_matches_list.addItem("No charter matches found")
            
            # Fetch and display linked receipts
            linked_matches = self._fetch_linked_matches(receipt_id)
            if linked_matches:
                for rid, rdate, rvend, ramt, rgl, rbank, rchar in linked_matches:
                    item_text = f"#{rid} • {rdate} • {rvend[:25]} • ${ramt:,.2f}"
                    item = QListWidgetItem(item_text)
                    item.setData(Qt.ItemDataRole.UserRole, rid)
                    self.linked_receipts_list.addItem(item)
            else:
                self.linked_receipts_list.addItem("No linked receipts found")
            
            # Show the pane
            self.matches_pane.setVisible(True)
            self.matches_tabs.setCurrentIndex(0)  # Default to banking matches
            
        except Exception as e:
            QMessageBox.critical(self, "Error", f"Could not load split matches:\n{e}")

