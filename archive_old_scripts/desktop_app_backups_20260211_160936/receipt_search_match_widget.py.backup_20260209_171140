    def _quick_load_year(self, year: int):
        """Load all receipts for a specific year."""
        self.date_from.setDate(QDate(year, 1, 1))
        self.date_to.setDate(QDate(year, 12, 31))
        self.vendor_filter.clear()
        self.charter_filter.clear()
        self.amount_filter.setValue(0)
        self._do_search()
    
    def _quick_load_days(self, days: int):
        """Load receipts for last N days."""
        self.date_from.setDate(QDate.currentDate().addDays(-days))
        self.date_to.setDate(QDate.currentDate())
        self.vendor_filter.clear()
        self.charter_filter.clear()
        self.amount_filter.setValue(0)
        self._do_search()
    
    def _quick_load_all(self):
        """Load all receipts (warning: can be slow)."""
        reply = QMessageBox.question(
            self,
            "Load All Receipts?",
            "Loading all receipts may take 10-30 seconds and could freeze the UI.\n\nContinue?",
            QMessageBox.StandardButton.Yes | QMessageBox.StandardButton.No,
            QMessageBox.StandardButton.No
        )
        if reply == QMessageBox.StandardButton.Yes:
            # Set very wide date range
            self.date_from.setDate(QDate(2010, 1, 1))
            self.date_to.setDate(QDate.currentDate().addYears(1))
            self.vendor_filter.clear()
            self.charter_filter.clear()
            self.amount_filter.setValue(0)
            self._do_search()

